<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.ui.ImportController"
            styleClass="root-pane">

    <!-- ── Top Bar ──────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="10" right="20" bottom="10" left="16"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="icon-button"/>
            <HBox styleClass="logo-pill" alignment="CENTER">
                <padding><Insets top="5" right="14" bottom="5" left="14"/></padding>
                <ImageView fitWidth="52" fitHeight="52" preserveRatio="true">
                    <viewport><Rectangle2D minX="180" minY="60" width="660" height="660"/></viewport>
                    <image><Image url="@/images/rasoi.png"/></image>
                </ImageView>
            </HBox>
            <Label text="|" style="-fx-text-fill:rgba(255,255,255,0.35);-fx-font-size:18;-fx-padding:0 2 0 2;"/>
            <Label text="Import Data from Excel" styleClass="app-title"/>
        </HBox>
    </top>

    <!-- ── Body ─────────────────────────────────────────────────────── -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <padding><Insets top="10" right="16" bottom="16" left="16"/></padding>

            <!-- ── Menu Items Tab ──────────────────────────────────── -->
            <Tab text="Menu Items">
                <VBox spacing="14" styleClass="content-panel">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🍽" style="-fx-font-size:24;"/>
                        <Label text="Import Menu Items" styleClass="section-header"/>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <Button text="⬇ Download Sample Template"
                                onAction="#handleDownloadMenuTemplate"
                                styleClass="secondary-button"/>
                    </HBox>
                    <Separator/>

                    <!-- File chooser row -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="📂 Choose Excel File"
                                onAction="#handleChooseMenuFile"
                                styleClass="primary-button"/>
                        <Label fx:id="menuFileLabel" text="No file selected"
                               style="-fx-font-size:12;-fx-text-fill:#6c757d;"/>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <ProgressBar fx:id="menuProgressBar" prefWidth="160" prefHeight="18"/>
                    </HBox>

                    <!-- Expected columns info -->
                    <VBox styleClass="info-card" spacing="5">
                        <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
                        <Label text="Expected columns (in order):" styleClass="form-label"/>
                        <Label text="A: Name  |  B: Category  |  C: Price  |  D: Description  |  E: Available (YES/NO)"
                               style="-fx-font-family:monospace;-fx-font-size:12;"/>
                        <Label text="• Row 1 is treated as a header and skipped."
                               styleClass="login-hint"/>
                        <Label text="• Duplicate names (case-insensitive) are skipped with a warning."
                               styleClass="login-hint"/>
                    </VBox>

                    <!-- Preview table -->
                    <Label text="Data Preview (first 50 rows)" styleClass="form-label"/>
                    <TableView fx:id="menuPreviewTable" VBox.vgrow="ALWAYS" prefHeight="280">
                        <placeholder><Label text="Choose an Excel file to see a preview"/></placeholder>
                    </TableView>

                    <!-- Action row -->
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button fx:id="menuImportButton" text="✔ Import Menu Items"
                                onAction="#handleImportMenu"
                                styleClass="success-button" disable="true"
                                style="-fx-font-size:13;-fx-padding:9 20;"/>
                    </HBox>

                    <!-- Result area -->
                    <TextArea fx:id="menuResultArea" editable="false" prefHeight="110" wrapText="true"
                              promptText="Import results will appear here..."
                              style="-fx-font-family:'Courier New';-fx-font-size:11;
                                     -fx-background-color:#f8f9fa;-fx-border-color:#dee2e6;"/>
                </VBox>
            </Tab>

            <!-- ── Orders Tab ──────────────────────────────────────── -->
            <Tab text="Order History">
                <VBox spacing="14" styleClass="content-panel">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="📋" style="-fx-font-size:24;"/>
                        <Label text="Import Order History" styleClass="section-header"/>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <Button text="⬇ Download Sample Template"
                                onAction="#handleDownloadOrderTemplate"
                                styleClass="secondary-button"/>
                    </HBox>
                    <Separator/>

                    <!-- File chooser row -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="📂 Choose Excel File"
                                onAction="#handleChooseOrdersFile"
                                styleClass="primary-button"/>
                        <Label fx:id="ordersFileLabel" text="No file selected"
                               style="-fx-font-size:12;-fx-text-fill:#6c757d;"/>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <ProgressBar fx:id="ordersProgressBar" prefWidth="160" prefHeight="18"/>
                    </HBox>

                    <!-- Expected columns info -->
                    <VBox styleClass="info-card" spacing="5">
                        <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
                        <Label text="Expected columns (in order):" styleClass="form-label"/>
                        <Label text="A: Order #  |  B: Table  |  C: Customer  |  D: Date (dd-MM-yyyy)  |  E: Item Name  |  F: Qty  |  G: Unit Price  |  H: Tax %  |  I: Payment"
                               wrapText="true"
                               style="-fx-font-family:monospace;-fx-font-size:12;"/>
                        <Label text="• One row per order-item; rows with the same Order # are grouped."
                               styleClass="login-hint"/>
                        <Label text="• Duplicate order numbers are skipped with a warning."
                               styleClass="login-hint"/>
                        <Label text="• Item names must match existing menu items exactly (case-insensitive)."
                               styleClass="login-hint"/>
                    </VBox>

                    <!-- Preview table -->
                    <Label text="Data Preview (first 50 rows)" styleClass="form-label"/>
                    <TableView fx:id="ordersPreviewTable" VBox.vgrow="ALWAYS" prefHeight="280">
                        <placeholder><Label text="Choose an Excel file to see a preview"/></placeholder>
                    </TableView>

                    <!-- Action row -->
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button fx:id="ordersImportButton" text="✔ Import Orders"
                                onAction="#handleImportOrders"
                                styleClass="success-button" disable="true"
                                style="-fx-font-size:13;-fx-padding:9 20;"/>
                    </HBox>

                    <!-- Result area -->
                    <TextArea fx:id="ordersResultArea" editable="false" prefHeight="110" wrapText="true"
                              promptText="Import results will appear here..."
                              style="-fx-font-family:'Courier New';-fx-font-size:11;
                                     -fx-background-color:#f8f9fa;-fx-border-color:#dee2e6;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
