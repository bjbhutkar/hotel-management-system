<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.ui.AccountingExportController"
            styleClass="root-pane">

    <!-- ── Top Bar ──────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="10" right="20" bottom="10" left="16"/></padding>
            <Button text="← Back" onAction="#handleBack" styleClass="icon-button"/>
            <HBox styleClass="logo-pill" alignment="CENTER">
                <padding><Insets top="5" right="14" bottom="5" left="14"/></padding>
                <ImageView fitWidth="52" fitHeight="52" preserveRatio="true">
                    <viewport><Rectangle2D minX="180" minY="60" width="660" height="660"/></viewport>
                    <image><Image url="@/images/rasoi.png"/></image>
                </ImageView>
            </HBox>
            <Label text="|" style="-fx-text-fill:rgba(255,255,255,0.35);-fx-font-size:18;-fx-padding:0 2 0 2;"/>
            <Label text="Accounting Export" styleClass="app-title"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" wrapText="true" maxWidth="500"
                   style="-fx-font-size:12;-fx-font-weight:bold;"/>
        </HBox>
    </top>

    <!-- ── Body ─────────────────────────────────────────────────────── -->
    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- ── Date Range & Load ─────────────────────────────────── -->
            <HBox styleClass="content-panel" spacing="16" alignment="CENTER_LEFT">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <Label text="📅" style="-fx-font-size:20;"/>
                <Label text="Export Period" styleClass="section-header"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label text="From:" styleClass="form-label"/>
                <DatePicker fx:id="fromDatePicker" prefWidth="145"/>
                <Label text="To:" styleClass="form-label"/>
                <DatePicker fx:id="toDatePicker" prefWidth="145"/>
                <Button text="⟳  Load Orders" onAction="#handleLoadOrders" styleClass="primary-button"
                        style="-fx-font-size:13;-fx-padding:8 20;"/>
            </HBox>

            <!-- ── Summary Cards ─────────────────────────────────────── -->
            <HBox spacing="16" alignment="CENTER">
                <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100">
                    <Label text="📋  Total Orders" styleClass="stat-label"/>
                    <Label fx:id="totalOrdersLabel" text="—" styleClass="stat-value"
                           style="-fx-font-size:28;"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-green" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100">
                    <Label text="💰  Taxable Sales" styleClass="stat-label"/>
                    <Label fx:id="subtotalLabel" text="₹0.00" styleClass="stat-value"
                           style="-fx-font-size:22;"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-blue" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100">
                    <Label text="🔖  Output CGST" styleClass="stat-label"/>
                    <Label fx:id="cgstLabel" text="₹0.00" styleClass="stat-value"
                           style="-fx-font-size:22;"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-blue" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100">
                    <Label text="🔖  Output SGST" styleClass="stat-label"/>
                    <Label fx:id="sgstLabel" text="₹0.00" styleClass="stat-value"
                           style="-fx-font-size:22;"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-orange" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100">
                    <Label text="🧾  Total GST" styleClass="stat-label"/>
                    <Label fx:id="totalGstLabel" text="₹0.00" styleClass="stat-value"
                           style="-fx-font-size:22;"/>
                </VBox>
                <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
                      prefWidth="190" prefHeight="100"
                      style="-fx-border-color:#27ae60;-fx-border-width:0 0 4 0;">
                    <Label text="💵  Total Revenue" styleClass="stat-label"/>
                    <Label fx:id="totalRevenueLabel" text="₹0.00" styleClass="stat-value"
                           style="-fx-font-size:22;"/>
                </VBox>
            </HBox>

            <!-- ── Orders Table ──────────────────────────────────────── -->
            <VBox VBox.vgrow="ALWAYS" styleClass="content-panel" spacing="10">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="🗒" style="-fx-font-size:16;"/>
                    <Label text="Billed Orders Preview" styleClass="section-header"/>
                    <Label fx:id="orderCountLabel" text="" styleClass="form-label"
                           style="-fx-text-fill:#6c757d;-fx-padding:2 0 0 4;"/>
                </HBox>
                <Separator/>

                <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" tableMenuButtonVisible="false">
                    <columns>
                        <TableColumn fx:id="colOrderNum"   text="Order #"       prefWidth="150"/>
                        <TableColumn fx:id="colDate"       text="Date &amp; Time" prefWidth="160"/>
                        <TableColumn fx:id="colCustomer"   text="Customer"      prefWidth="160"/>
                        <TableColumn fx:id="colTable"      text="Table"         prefWidth="70"/>
                        <TableColumn fx:id="colSubtotal"   text="Subtotal (₹)"  prefWidth="120"/>
                        <TableColumn fx:id="colTaxRate"    text="GST %"         prefWidth="80"/>
                        <TableColumn fx:id="colCgst"       text="CGST (₹)"      prefWidth="110"/>
                        <TableColumn fx:id="colSgst"       text="SGST (₹)"      prefWidth="110"/>
                        <TableColumn fx:id="colTotal"      text="Total (₹)"     prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="Select a date range and click 'Load Orders' to preview data."
                               style="-fx-text-fill:#6c757d;-fx-font-size:13;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ── Export Buttons ────────────────────────────────────── -->
            <HBox styleClass="content-panel" spacing="20" alignment="CENTER">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>

                <VBox styleClass="info-card" spacing="6" HBox.hgrow="ALWAYS">
                    <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
                    <Label text="ℹ Tally Setup Note" styleClass="form-label"/>
                    <Label wrapText="true" styleClass="login-hint"
                           text="Before importing, create these ledgers in Tally: 'Restaurant Sales' (under Sales Accounts), 'Output CGST @ 9%' and 'Output SGST @ 9%' (under Duties &amp; Taxes), and 'Cash' (auto-exists)."/>
                </VBox>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button fx:id="exportExcelBtn" text="📊  Export to Excel"
                            onAction="#handleExportExcel"
                            styleClass="success-button"
                            style="-fx-font-size:14;-fx-padding:12 28;"
                            disable="true"/>
                    <Button fx:id="exportTallyBtn" text="📁  Export to Tally XML"
                            onAction="#handleExportTally"
                            styleClass="primary-button"
                            style="-fx-font-size:14;-fx-padding:12 28;"
                            disable="true"/>
                </HBox>
            </HBox>

        </VBox>
    </center>
</BorderPane>
